# Data mode: auto | api | csv
# - auto: CSV-first + API merge when available
# - api: API first, CSV fallback if API has no usable rows
# - csv: CSV only (no API calls for that platform)
X_DATA_MODE=auto
LINKEDIN_DATA_MODE=auto

# API refresh mode: manual | auto
# - manual: only fetch API when clicking Manual API Refresh
# - auto: allow API fetches during normal page loads (cached)
API_REFRESH_MODE=manual

# X API (required only for X API mode)
X_API_BEARER_TOKEN=
X_API_USERNAME=
X_API_LOOKBACK_DAYS=30
# Server-side cache TTL for API calls
X_API_CACHE_SECONDS=900
# Manual refresh guardrails
X_API_REFRESH_COOLDOWN_SECONDS=120
X_API_DAILY_REFRESH_CAP=15

# X API intelligence modules
X_MENTIONS_LOOKBACK_DAYS=30
X_MENTIONS_SPIKE_RATIO_THRESHOLD=1.8
X_MENTIONS_SPIKE_DELTA_THRESHOLD=5
X_QUOTE_SOURCE_POST_LIMIT=12
X_QUOTE_HIGH_INTENT_ENGAGEMENT_THRESHOLD=5
X_AMPLIFIER_SOURCE_POST_LIMIT=8
X_REPEAT_SUPPORTER_THRESHOLD=5
X_FOLLOWER_HISTORY_LIMIT=180
X_FOLLOWER_SNAPSHOT_MIN_MINUTES=30
X_POST_SNAPSHOT_HISTORY_LIMIT=90
X_POST_SNAPSHOT_MIN_MINUTES=30
X_POST_SNAPSHOT_POST_LIMIT=250
X_HALF_LIFE_MIN_FINAL_ENGAGEMENTS=10

# Optional brand listening (X recent search)
# X_BRAND_QUERY=(canary OR #canary)
# X_BRAND_COMPARE_QUERY=(competitor1 OR competitor2)
X_BRAND_LOOKBACK_DAYS=7

# LinkedIn API (optional in v1; CSV fallback remains active)
LINKEDIN_API_ACCESS_TOKEN=
# Can be either numeric id (e.g. 123456) or full urn:li:organization:123456
LINKEDIN_ORGANIZATION_URN=
LINKEDIN_API_LOOKBACK_DAYS=30
LINKEDIN_API_CACHE_SECONDS=900
# Optional: defaults to https://api.linkedin.com/rest
# LINKEDIN_API_BASE_URL=
# Optional: defaults to 202506
# LINKEDIN_API_VERSION=

# Optional CSV file overrides
# X_CSV_PATH=x_account_analytics.csv
# X_POSTS_CSV_PATH=x_post_analytics.csv
# X_VIDEO_OVERVIEW_CSV_PATH=x_video_overview.csv
# LINKEDIN_CSV_PATH=linkedin_metrics.csv
# LINKEDIN_POSTS_CSV_PATH=linkedin_posts.csv
# LINKEDIN_VISITORS_CSV_PATH=linkedin_visitors.csv
# LINKEDIN_FOLLOWERS_CSV_PATH=linkedin_followers.csv
